{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "ClaimsIQ — API performance, claim throughput, error rates, and live logs",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "SLI — HTTP Traffic",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 10},
            {"color": "red", "value": 50}
          ]},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "Request Rate",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "sum(rate(http_requests_total{job=\"claimsiq_backend\"}[2m]))",
        "legendFormat": "req/s"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.01},
            {"color": "red", "value": 0.05}
          ]},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "Error Rate (5xx)",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "sum(rate(http_requests_total{job=\"claimsiq_backend\",status=~\"5..\"}[2m])) / sum(rate(http_requests_total{job=\"claimsiq_backend\"}[2m]))",
        "legendFormat": "5xx rate"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.5},
            {"color": "red", "value": 1}
          ]},
          "unit": "s"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "value"},
      "title": "P95 Latency",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"claimsiq_backend\"}[5m])) by (le))",
        "legendFormat": "p95"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 1},
            {"color": "red", "value": 2}
          ]},
          "unit": "s"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "value"},
      "title": "P99 Latency",
      "type": "stat",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"claimsiq_backend\"}[5m])) by (le))",
        "legendFormat": "p99"
      }]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "5xx"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "4xx"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "2xx"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "id": 5,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "HTTP Request Rate by Status Class",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(http_requests_total{job=\"claimsiq_backend\",status=~\"2..\"}[2m]))",
          "legendFormat": "2xx"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(http_requests_total{job=\"claimsiq_backend\",status=~\"4..\"}[2m]))",
          "legendFormat": "4xx"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(http_requests_total{job=\"claimsiq_backend\",status=~\"5..\"}[2m]))",
          "legendFormat": "5xx"
        }
      ]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "id": 6,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"claimsiq_backend\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"claimsiq_backend\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"claimsiq_backend\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13},
      "id": 101,
      "title": "Claims Throughput",
      "type": "row"
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "id": 7,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Claims Submitted vs Adjudicated (req/s)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(http_requests_total{job=\"claimsiq_backend\",handler=\"/api/v1/claims/\",method=\"POST\",status=\"201\"}[5m]))",
          "legendFormat": "submitted"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(http_requests_total{job=\"claimsiq_backend\",handler=~\".*/claims/.*\",status=\"200\"}[5m]))",
          "legendFormat": "adjudicated"
        }
      ]
    },

    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "id": 8,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "Slowest Endpoints (p95 latency)",
      "type": "timeseries",
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "topk(5, histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"claimsiq_backend\"}[5m])) by (handler, le)))",
        "legendFormat": "{{handler}}"
      }]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22},
      "id": 102,
      "title": "Live Logs (Loki)",
      "type": "row"
    },

    {
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 23},
      "id": 9,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true
      },
      "title": "Backend Logs (errors & warnings)",
      "type": "logs",
      "targets": [{
        "datasource": {"type": "loki", "uid": "loki"},
        "expr": "{container_name=\"claims-backend\"} |= `` | json | level=~\"error|warning|critical\"",
        "legendFormat": ""
      }]
    },

    {
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 33},
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true
      },
      "title": "All Backend Logs",
      "type": "logs",
      "targets": [{
        "datasource": {"type": "loki", "uid": "loki"},
        "expr": "{container_name=\"claims-backend\"}",
        "legendFormat": ""
      }]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["claimsiq", "backend", "sli"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "ClaimsIQ — Overview",
  "uid": "claimsiq-overview",
  "version": 1
}
