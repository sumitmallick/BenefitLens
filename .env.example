# ─────────────────────────────────────────────────────────────────────────────
# ClaimsIQ — environment variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# .env is git-ignored. Never commit actual secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────

# Async DSN used by the FastAPI app (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://claims:claims@postgres:5432/claimsdb

# Sync DSN used by Alembic for migrations
DATABASE_URL_SYNC=postgresql://claims:claims@postgres:5432/claimsdb

# For running migrations locally (outside Docker):
# DATABASE_URL_SYNC=postgresql://claims:claims@localhost:5432/claimsdb


# ── Redis ─────────────────────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379/0

# Feature flag — set to false to skip Redis (falls back to no caching)
ENABLE_REDIS_CACHE=true


# ── Application ───────────────────────────────────────────────────────────────

# development | production
ENVIRONMENT=development

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# JSON array of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000"]


# ── JWT Authentication ────────────────────────────────────────────────────────

# REQUIRED in production — minimum 32 characters, high entropy.
# Generate a secure key:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-change-in-production-min-32-chars!!

# Token algorithm — HS256 is fine for single-service; use RS256 for multi-service
JWT_ALGORITHM=HS256

# Token lifetime in minutes (default: 1440 = 24 hours)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440


# ── PHI Encryption ────────────────────────────────────────────────────────────

# Fernet AES-128-CBC key for encrypting PHI columns (phi_* prefixed fields).
# REQUIRED in production. Empty = plaintext storage (dev only — will log a warning).
#
# Generate a production key:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Store the generated value in your secrets manager (AWS Secrets Manager,
# Vault, K8s Secret) — never hard-code it here in production.
PHI_ENCRYPTION_KEY=


# ── Kafka (optional event streaming) ─────────────────────────────────────────

# Set to true to publish domain events to Kafka.
# Also uncomment the kafka/zookeeper services in docker-compose.yml.
ENABLE_KAFKA=false

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EVENTS_TOPIC=claims.events


# ── Frontend (Next.js) ────────────────────────────────────────────────────────

# Base URL the browser uses to reach the backend API.
# In Docker Compose: http://localhost:8000
# In Kubernetes / production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000


# ── Test database (used by pytest integration tests) ──────────────────────────

# Separate DB so tests never touch development data.
# Created automatically by the test suite if it doesn't exist.
TEST_DATABASE_URL=postgresql+asyncpg://claims:claims@localhost:5432/claimsdb_test
