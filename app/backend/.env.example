# Copy to .env and fill in values

# Database (async)
DATABASE_URL=postgresql+asyncpg://claims:claims@localhost:5432/claimsdb
DATABASE_URL_SYNC=postgresql://claims:claims@localhost:5432/claimsdb

# Redis
REDIS_URL=redis://localhost:6379/0

# PHI Encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty for dev (PHI stored as plaintext — not for production)
PHI_ENCRYPTION_KEY=

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# Kafka (optional)
ENABLE_KAFKA=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_EVENTS_TOPIC=claims.events

# Feature flags
ENABLE_REDIS_CACHE=true
